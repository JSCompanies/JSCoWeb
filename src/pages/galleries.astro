---
const brand = "JaiSellers Companies";
const title = "Galleries";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {brand}</title>
    <meta
      name="description"
      content="A curated galleries page showcasing visual moments from JaiSellers Companies."
    />
    <link rel="stylesheet" href="/site.css" />
    <style>
      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-top: 20px;
      }
      .gallery-item {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: rgba(18,20,26,.55);
        box-shadow: var(--shadow);
        overflow: hidden;
      }
      .gallery-item img {
        width: 100%;
        aspect-ratio: 4 / 5;
        object-fit: cover;
        display: block;
      }
      .gallery-item figcaption {
        padding: 12px 14px;
        color: var(--muted);
        font-size: 14px;
      }
      @media (max-width: 900px) {
        .gallery-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <a class="logo" href="/">{brand}</a>
      <nav class="nav">
        <a href="/consulting">Consulting (JSC)</a>
        <a href="/design">Design</a>
        <a href="/jsi">JSI</a>
        <a href="/about">About</a>
        <a href="/blog">Insights</a>
        <a class="nav-cta" href="/contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="section">
        <div class="container">
          <p class="kicker">Portfolio</p>
          <h1>{title}</h1>
          <p style="margin-top:14px; max-width:70ch;">
            A visual collection of moments, identity, and mission-centered work across JaiSellers Companies.
          </p>

          <div class="gallery-grid" aria-label="Image galleries">
            <figure class="gallery-item">
              <img src="/images/Me (1).png" alt="Portrait from the JaiSellers Companies gallery" loading="lazy" />
              <figcaption>Leadership portrait</figcaption>
            </figure>
            <figure class="gallery-item">
              <img src="/images/Me (2).png" alt="Community-focused visual from the gallery" loading="lazy" />
              <figcaption>Community-centered work</figcaption>
            </figure>
            <figure class="gallery-item">
              <img src="/images/Me (3).png" alt="Professional studio image from the gallery" loading="lazy" />
              <figcaption>Studio identity</figcaption>
            </figure>
            <figure class="gallery-item">
              <img src="/images/Me (4).png" alt="Creative portrait in the JaiSellers gallery" loading="lazy" />
              <figcaption>Creative direction</figcaption>
            </figure>
            <figure class="gallery-item">
              <img src="/images/Me (5).png" alt="Brand-focused portrait from the gallery" loading="lazy" />
              <figcaption>Brand expression</figcaption>
            </figure>
            <figure class="gallery-item">
              <img src="/images/Me (6).png" alt="Mission-driven portrait from the gallery page" loading="lazy" />
              <figcaption>Mission in focus</figcaption>
            </figure>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} {brand}</span>
        <span class="sep">•</span>
        <a href="/contact">Contact</a>
      </div>
    </footer>
  </body>
</html>
