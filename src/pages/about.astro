---
const brand = "JaiSellers Companies";
const title = "About";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {brand}</title>
    <meta
      name="description"
      content="Founder-led infrastructure studio building governance, funding, and narrative systems for mission-driven work."
    />
    <link rel="stylesheet" href="/site.css" />
  </head>

  <body>
    <!-- Top navigation -->
    <header class="topbar">
      <a class="logo" href="/">{brand}</a>
      <nav class="nav">
        <a href="/consulting">Consulting (JSC)</a>
        <a href="/design">Design</a>
        <a href="/jsi">JSI</a>
        <a href="/about">About</a>
        <a class="nav-cta" href="/contact">Contact</a>
      </nav>
    </header>

    <!-- Main content -->
    <main class="section">
      <div class="container">
        <p class="kicker">About</p>
        <h1>Founder-led. Systems-first.</h1>

        <!-- Your photo -->
        <img
          src="/images/AboutMe.png"
          alt="Photo of Joshua Jai Sellers"
          style="max-width: 300px; border-radius: 12px; margin-top: 20px;"
        />

        <p style="margin-top:14px; max-width:76ch;">
          JaiSellers Companies operates at the seam where creativity, strategy, and advocacy meet—
          honoring legacy while building what’s next.
        </p>

        <!-- Contact form -->
        <h2 style="margin-top:32px;">Get in touch</h2>
        <form
          action="mailto:joshuajaisellers@gmail.com"
          method="POST"
          enctype="text/plain"
          style="display: grid; gap: 12px; max-width: 400px;"
        >
          <label>
            Name:
            <input type="text" name="name" required style="width:100%; padding:8px; border-radius:4px;" />
          </label>
          <label>
            Email:
            <input type="email" name="email" required style="width:100%; padding:8px; border-radius:4px;" />
          </label>
          <label>
            Message:
            <textarea
              name="message"
              rows="4"
              required
              style="width:100%; padding:8px; border-radius:4px;"
            ></textarea>
          </label>
          <button
            type="submit"
            style="padding:10px 16px; background:#caa24a; color:#15110a; border:none; border-radius:24px; cursor:pointer;"
          >
            Send
          </button>
        </form>
        <p class="small" style="margin-top:8px;">
          This form opens your default mail client. Swap `action` for a service like Formspree or Netlify Forms if you need submissions processed automatically.
        </p>
      </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} {brand}</span>
        <span class="sep">•</span>
        <a href="/contact">Contact</a>
      </div>
    </footer>
  </body>
</html>
