---
const brand = "JaiSellers Companies";
const title = "Portfolio";
const email = "joshuajaisellers@gmail.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {brand}</title>
    <meta
      name="description"
      content="Work samples and case studies from JaiSellers Companies — governance builds, brand systems, and justice-focused initiatives."
    />
    <link rel="stylesheet" href="/site.css" />
    <style>
      .portfolio-hero {
        padding: clamp(56px, 8vw, 100px) 0 clamp(48px, 6vw, 80px);
        border-bottom: 1px solid var(--line);
      }
      .filter-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 28px;
      }
      .filter-pill {
        font-size: 12px;
        color: rgba(244,242,238,.82);
        border: 1px solid var(--line);
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(18,20,26,.55);
        cursor: default;
      }
      .filter-pill.active {
        background: rgba(202,162,74,.18);
        border-color: rgba(202,162,74,.5);
        color: var(--gold);
      }
      .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 28px;
      }
      @media (max-width: 700px) {
        .portfolio-grid { grid-template-columns: 1fr; }
      }
      .portfolio-card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: rgba(18,20,26,.55);
        box-shadow: var(--shadow);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .portfolio-card-header {
        padding: 24px 24px 0;
      }
      .portfolio-card-body {
        padding: 14px 24px 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .portfolio-card .tag {
        display: inline-block;
        font-size: 11px;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--gold);
        border: 1px solid rgba(202,162,74,.35);
        padding: 4px 10px;
        border-radius: 999px;
        margin-bottom: 12px;
      }
      .portfolio-card h3 {
        font-size: 18px;
        margin-bottom: 10px;
      }
      .portfolio-card p {
        font-size: 14px;
        line-height: 1.6;
        margin-top: 0;
      }
      .portfolio-card .outcome-list {
        list-style: none;
        margin: 12px 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .portfolio-card .outcome-list li {
        font-size: 13px;
        color: rgba(244,242,238,.75);
        display: flex;
        align-items: flex-start;
        gap: 8px;
        line-height: 1.4;
      }
      .portfolio-card .outcome-list li::before {
        content: "✓";
        color: var(--gold);
        flex-shrink: 0;
        font-size: 12px;
        margin-top: 1px;
      }
      .portfolio-card .card-footer {
        margin-top: auto;
        padding-top: 16px;
        border-top: 1px solid var(--line);
      }
      .divider {
        border: none;
        border-top: 1px solid var(--line);
        margin: 0;
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <a class="logo" href="/">
        <img src="/images/logo.svg" alt="JaiSellers Companies" class="logo-img" />
      </a>
      <nav class="nav">
        <a href="/consulting">Consulting (JSC)</a>
        <a href="/design">Design</a>
        <a href="/jsi">JSI</a>
        <a href="/portfolio">Portfolio</a>
