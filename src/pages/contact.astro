---
const brand = "JaiSellers Companies";
const title = "Contact";
const email = "joshuajaisellers@gmail.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {brand}</title>
    <meta
      name="description"
      content="Contact JaiSellers Companies. Start a conversation about consulting, design, or partnership."
    />
    <link rel="stylesheet" href="/site.css" />
    <style>
      /* ── Contact-page-specific styles ── */
      .contact-hero {
        padding: clamp(64px, 9vw, 110px) 0 clamp(52px, 7vw, 88px);
        border-bottom: 1px solid var(--line);
      }
      .contact-hero h1 {
        font-size: clamp(38px, 6vw, 72px);
        max-width: 18ch;
        line-height: 1.04;
      }
      .contact-hero .subhead {
        margin-top: 18px;
        max-width: 60ch;
      }
      .contact-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 24px;
        align-items: start;
        margin-top: 28px;
      }
      @media (max-width: 900px) {
        .contact-grid { grid-template-columns: 1fr; }
      }
      .contact-detail {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 20px 0;
        border-top: 1px solid var(--line);
      }
      .contact-detail:last-child { border-bottom: 1px solid var(--line); }
      .contact-detail .label {
        font-size: 11px;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--gold);
      }
      .contact-detail .value {
        font-size: 15px;
        color: var(--text);
      }
      .contact-detail .value a {
        color: var(--text);
        border-bottom: 1px solid rgba(202,162,74,.4);
        padding-bottom: 1px;
      }
      .contact-detail .value a:hover { color: var(--gold); }
      .panel {
        background: var(--bg2);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 28px 24px;
        box-shadow: var(--shadow);
      }
      .panel h3 {
        font-size: 16px;
        letter-spacing: -0.01em;
        border-bottom: 1px solid var(--line);
        padding-bottom: 14px;
        margin-bottom: 16px;
      }
      .intake-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .intake-list li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        font-size: 14px;
        color: var(--muted);
        line-height: 1.5;
      }
      .intake-list li .num {
        color: var(--gold);
        font-weight: 700;
        font-size: 13px;
        flex-shrink: 0;
        margin-top: 1px;
        min-width: 18px;
      }
      .scope-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
      }
      .response-note {
        margin-top: 18px;
        padding: 14px 16px;
        background: rgba(202,162,74,.08);
        border-left: 2px solid var(--gold);
        border-radius: 0 8px 8px 0;
        font-size: 13px;
        color: rgba(244,242,238,.80);
        line-height: 1.55;
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <a class="logo" href="/">{brand}</a>
      <nav class="nav">
        <a href="/consulting">Consulting (JSC)</a>
        <a href="/design">Design</a>
        <a href="/jsi">JSI</a>
<<<<<<< Updated upstream
=======
        <a href="/portfolio">Portfolio</a>
>>>>>>> Stashed changes
        <a href="/about">About</a>
        <a href="/blog">Insights</a>
        <a class="nav-cta" href="/contact">Contact</a>
      </nav>
    </header>

    <main>

      <!-- ── Hero ── -->
      <section class="contact-hero">
        <div class="container">
          <p class="kicker">Contact</p>
          <h1>Let's build something that holds.</h1>
          <p class="subhead">
            Tell me what you're working on, what's urgent, and what a successful outcome looks
            like. I'll respond with a clear path forward.
          </p>

          <div class="cta-row" style="margin-top:28px;">
            <a class="btn primary" href={"mailto:" + email + "?subject=JaiSellers%20Companies%20Inquiry"}>
              Send an email
            </a>
            <a class="btn ghost" href="/consulting">View services first</a>
          </div>

          <div class="trust-row" style="margin-top:22px;">
            <span class="pill">Nonprofit formation</span>
            <span class="pill">Grant systems</span>
            <span class="pill">Brand + identity</span>
            <span class="pill">Justice navigation</span>
            <span class="pill">JSI partnerships</span>
          </div>
        </div>
      </section>

      <!-- ── Details + Panel ── -->
      <section class="section">
        <div class="container contact-grid">

          <!-- Left: contact details -->
          <div>
            <p class="kicker" style="margin-bottom:22px;">Reach out directly</p>

            <div class="contact-detail">
              <span class="label">Email</span>
              <span class="value">
                <a href={"mailto:" + email}>{email}</a>
              </span>
            </div>

            <div class="contact-detail">
              <span class="label">Mailing address</span>
              <span class="value">912 S. Battleground Ave.<br />Kings Mountain, NC 28086</span>
            </div>

            <div class="contact-detail">
              <span class="label">Base of operations</span>
              <span class="value">Cleveland County, North Carolina</span>
            </div>

            <div class="contact-detail">
              <span class="label">Response time</span>
              <span class="value">Within 2 business days</span>
            </div>

            <p style="margin-top:28px; max-width:56ch; font-size:14px;">
              I work with a small number of clients at a time to keep the quality of work high.
              If you're serious about building something durable, I want to hear from you.
            </p>
          </div>

          <!-- Right: intake panel -->
          <div>
            <div class="panel">
              <h3>What to include in your message</h3>
              <ol class="intake-list">
                <li>
                  <span class="num">01</span>
                  <span>Your organization's name, location, and current stage</span>
                </li>
                <li>
                  <span class="num">02</span>
                  <span>What you need — formation, grants, brand, operations, or all of the above</span>
                </li>
                <li>
                  <span class="num">03</span>
                  <span>Any deadlines or time-sensitive constraints</span>
                </li>
                <li>
                  <span class="num">04</span>
                  <span>Current status — incorporated? EIN? Active board?</span>
                </li>
                <li>
                  <span class="num">05</span>
                  <span>Your budget range, if known</span>
                </li>
              </ol>

              <div class="scope-tags">
                <span class="pill">501(c)(3) formation</span>
                <span class="pill">Bylaws + governance</span>
                <span class="pill">Grant readiness</span>
                <span class="pill">Brand identity</span>
                <span class="pill">Board ops</span>
                <span class="pill">JSI partnership</span>
              </div>

              <div class="response-note">
                The more context you share upfront, the faster we can identify the right scope
                and get to work.
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── Closing CTA ── -->
      <section class="section section-alt">
        <div class="container split">
          <div>
            <h2>Not sure where to start?</h2>
            <p style="margin-top:12px; max-width:58ch;">
              Start with the Formation Machine — the fastest path from conviction to credible,
              compliant, fundable organization.
            </p>
            <a class="btn primary" href={"mailto:" + email + "?subject=Formation%20Machine%20Inquiry"} style="margin-top:18px; display:inline-flex;">
              Ask about Formation →
            </a>
          </div>
          <div class="callout" style="align-self:start;">
            <h3 style="color:var(--gold);">Already operating?</h3>
            <p style="margin-top:8px;">
              If you're running programs but struggling with funding, compliance, or brand — the
              Revenue Stack or Design Studio may be the right entry point.
            </p>
            <div class="cta-row" style="margin-top:14px;">
              <a class="btn ghost" href="/consulting" style="font-size:13px;">Consulting →</a>
              <a class="btn ghost" href="/design" style="font-size:13px;">Design →</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} {brand}</span>
        <span class="sep">•</span>
        <a href="/about">About</a>
        <span class="sep">•</span>
        <a href="/jsi">JSI</a>
      </div>
    </footer>
  </body>
</html>
