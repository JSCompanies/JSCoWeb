---
const brand = {
  kicker: "Honoring Stories. Building Systems. Driving Change.",
  headline: "Let's build something that holds.",
  subhead:
    "Reach out about consulting, brand systems, or grant strategy for your organization.",
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Contact | JaiSellers Companies</title>
</head>

<body>
  <main class="page">
    <section class="hero" aria-label="Contact">
      <div class="overlay" aria-hidden="true"></div>

      <div class="content">
        <p class="kicker">{brand.kicker}</p>
        <h1>{brand.headline}</h1>
        <p class="subhead">{brand.subhead}</p>

        <div class="contact-block">
          <a class="btn primary" href="mailto:joshuajaisellers@gmail.com">joshuajaisellers@gmail.com</a>
          <a class="btn" href="tel:+17047184209">704-718-4209</a>
        </div>

        <div class="actions">
          <a class="btn" href="/">Back home</a>
        </div>
      </div>
    </section>
  </main>

  <style>
    :global(body) {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background: #0b0b0c;
      color: rgba(243, 241, 236, 0.92);
    }

    .page {
      min-height: 100vh;
    }

    .hero {
      position: relative;
      min-height: 100vh;
      display: grid;
      align-items: center;
      overflow: hidden;
      background: radial-gradient(1200px 800px at 30% 20%, rgba(200,162,74,0.08), transparent 60%), #0b0b0c;
    }

    .overlay {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(700px 500px at 20% 40%, rgba(0,0,0,.18), transparent 60%),
        linear-gradient(to bottom, rgba(11,11,12,.2), rgba(11,11,12,.6));
    }

    .content {
      position: relative;
      z-index: 1;
      width: min(760px, calc(100% - 48px));
      margin: 0 auto;
      padding: 64px 0;
    }

    .kicker {
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: 12px;
      color: rgba(200, 162, 74, 0.95);
      margin: 0 0 14px;
    }

    h1 {
      font-size: clamp(38px, 5vw, 60px);
      line-height: 1.05;
      margin: 0 0 16px;
      max-width: 18ch;
    }

    .subhead {
      font-size: clamp(16px, 2vw, 20px);
      line-height: 1.5;
      max-width: 56ch;
      margin: 0 0 32px;
      color: rgba(243, 241, 236, 0.78);
    }

    .contact-block {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-radius: 999px;
      border: 1px solid rgba(243, 241, 236, 0.18);
      background: rgba(11, 11, 12, 0.35);
      backdrop-filter: blur(10px);
      color: inherit;
      text-decoration: none;
    }

    .btn:hover {
      opacity: 0.9;
    }

    .btn.primary {
      border-color: rgba(200, 162, 74, 0.35);
      box-shadow: 0 0 0 1px rgba(200, 162, 74, 0.15) inset;
    }
  </style>
</body>
</html>
