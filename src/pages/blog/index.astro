---
import { getCollection } from "astro:content";

const brand = "JaiSellers Companies";
const title = "Blog";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {brand}</title>
    <meta
      name="description"
      content="Insights on nonprofit governance, funding systems, brand identity, and justice work from JaiSellers Companies."
    />
    <link rel="stylesheet" href="/site.css" />
    <style>
      .blog-hero {
        padding: clamp(56px, 8vw, 96px) 0 clamp(40px, 5vw, 64px);
        border-bottom: 1px solid var(--line);
      }
      .blog-hero h1 {
        font-size: clamp(38px, 6vw, 64px);
      }
      .blog-hero .subhead {
        margin-top: 14px;
        max-width: 60ch;
      }
      .posts-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        margin-top: 40px;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        overflow: hidden;
      }
      .post-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: start;
        padding: 28px 24px;
        background: rgba(18, 20, 26, 0.55);
        border-bottom: 1px solid var(--line);
        transition: background 0.15s;
        text-decoration: none;
        color: inherit;
      }
      .post-row:last-child {
        border-bottom: none;
      }
      .post-row:hover {
        background: rgba(202, 162, 74, 0.06);
      }
      .post-row:hover .post-title {
        color: var(--gold);
      }
      .post-title {
        font-size: clamp(17px, 2vw, 21px);
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--text);
        margin: 0 0 8px;
        transition: color 0.15s;
      }
      .post-desc {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.55;
        max-width: 72ch;
        margin: 0;
      }
      .post-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
        flex-shrink: 0;
        padding-top: 2px;
      }
      .post-date {
        font-size: 13px;
        color: rgba(244, 242, 238, 0.55);
        white-space: nowrap;
      }
      .post-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .post-tag {
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--gold);
        border: 1px solid rgba(202, 162, 74, 0.35);
        padding: 3px 8px;
        border-radius: 999px;
      }
      .empty-state {
        text-align: center;
        padding: 72px 0;
        color: var(--muted);
      }
      @media (max-width: 640px) {
        .post-row {
          grid-template-columns: 1fr;
        }
        .post-meta {
          align-items: flex-start;
          flex-direction: row;
          flex-wrap: wrap;
        }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <a class="logo" href="/">{brand}</a>
      <nav class="nav">
        <a href="/consulting">Consulting (JSC)</a>
        <a href="/design">Design</a>
        <a href="/jsi">JSI</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a class="nav-cta" href="/contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="blog-hero">
        <div class="container">
          <p class="kicker">Insights &amp; thinking</p>
          <h1>The Blog</h1>
          <p class="subhead">
            Writing on nonprofit governance, funding systems, brand identity, and justice
            work — from a Cleveland County-rooted perspective.
          </p>
        </div>
      </section>

      <section class="section">
        <div class="container">
          {posts.length === 0 ? (
            <div class="empty-state">
              <p>No posts yet. Check back soon.</p>
            </div>
          ) : (
            <div class="posts-list">
              {posts.map((post) => (
                <a class="post-row" href={`/blog/${post.slug}`}>
                  <div>
                    <h2 class="post-title">{post.data.title}</h2>
                    <p class="post-desc">{post.data.description}</p>
                  </div>
                  <div class="post-meta">
                    <span class="post-date">{formatDate(post.data.pubDate)}</span>
                    {post.data.tags.length > 0 && (
                      <div class="post-tags">
                        {post.data.tags.map((tag) => (
                          <span class="post-tag">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} {brand}</span>
        <span class="sep">•</span>
        <a href="/contact">Contact</a>
        <span class="sep">•</span>
        <a href="/jsi">JSI</a>
        <span class="sep">•</span>
        <a href="/blog">Blog</a>
      </div>
    </footer>
  </body>
</html>
